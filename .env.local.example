# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Claude API (Anthropic) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Supabase (Phase 3+) — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Search Console API — for URL indexing submissions
GOOGLE_SEARCH_CONSOLE_KEY=

# Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=weight-loss.ca

# Site URL (used in sitemap, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://weight-loss.ca
